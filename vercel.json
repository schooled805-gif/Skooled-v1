{
  "buildCommand": "pnpm --filter @workspace/api-server exec node ./build.mjs && cp -r artifacts/api-server/dist dist",
  "installCommand": "pnpm install --ignore-scripts",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "dist/api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/dist/api/index.mjs" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
